{
  "manifest_version": 3,
  "name": "BulkStatus - Bulk URL Checker & Crawler",
  "short_name": "BulkStatus",
  "description": "Crawl and bulk-check URLs for status codes, broken links, redirects, images, and SEO metadata from a sitemap, llms.txt, or list.",
  "version": "1.0.0",
  "action": {
    "default_title": "Open BulkStatus - Bulk URL Checker & Crawler",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": [
    "power"
  ],
  "optional_permissions": [
    "scripting"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+B"
      }
    }
  }
}
